# TEMPLATE ONLY — DO NOT COMMIT WITH REAL VALUES
#
# Instructions:
#   1. Copy this file: cp k8s/secrets/secrets.yaml.example k8s/secrets/secrets.yaml
#   2. Replace every REPLACE_WITH_... placeholder with the actual value (plain text)
#   3. Apply: kubectl apply -f k8s/secrets/secrets.yaml -n chatbotsocket
#   4. Delete immediately: rm k8s/secrets/secrets.yaml
#
# stringData: accepts plain text — no base64 encoding needed.
# Kubernetes handles encoding internally.
#
# DATABASE_URL host inside K8s must be the postgres Service name:
#   postgresql://postgres:YOUR_PW@postgres-service:5432/ai_chatbot
#
apiVersion: v1
kind: Secret
metadata:
  name: chatbotsocket-secrets
  namespace: chatbotsocket
type: Opaque
stringData:
  DATABASE_URL: "postgresql://postgres:REPLACE_WITH_POSTGRES_PASSWORD@postgres-service:5432/ai_chatbot"
  ANTHROPIC_API_KEY: "REPLACE_WITH_ANTHROPIC_KEY"
  GEMINI_API_KEY: "REPLACE_WITH_GEMINI_KEY"
  NEXTAUTH_SECRET: "REPLACE_WITH_NEXTAUTH_SECRET"
  POSTGRES_USER: "postgres"
  POSTGRES_PASSWORD: "REPLACE_WITH_POSTGRES_PASSWORD"
  POSTGRES_DB: "ai_chatbot"
