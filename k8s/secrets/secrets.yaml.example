# TEMPLATE ONLY — DO NOT COMMIT WITH REAL VALUES
#
# Instructions:
#   1. Copy this file: cp k8s/secrets/secrets.yaml.example k8s/secrets/secrets.yaml
#   2. Fill in the base64-encoded values below
#   3. Apply: kubectl apply -f k8s/secrets/secrets.yaml -n chatbotsocket
#   4. Delete immediately: rm k8s/secrets/secrets.yaml
#
# How to base64-encode a value (no trailing newline):
#   echo -n "your-actual-value" | base64
#
# DATABASE_URL inside K8s must use the service name as host:
#   postgresql://postgres:YOUR_PW@postgres-service:5432/ai_chatbot
#
apiVersion: v1
kind: Secret
metadata:
  name: chatbotsocket-secrets
  namespace: chatbotsocket
type: Opaque
data:
  # echo -n "postgresql://postgres:YOUR_PW@postgres-service:5432/ai_chatbot" | base64
  DATABASE_URL: REPLACE_WITH_BASE64

  # echo -n "sk-ant-api03-..." | base64
  ANTHROPIC_API_KEY: REPLACE_WITH_BASE64

  # echo -n "AIza..." | base64
  GEMINI_API_KEY: REPLACE_WITH_BASE64

  # echo -n "$(openssl rand -base64 32)" | base64
  NEXTAUTH_SECRET: REPLACE_WITH_BASE64

  # echo -n "postgres" | base64  →  cG9zdGdyZXM=
  POSTGRES_USER: cG9zdGdyZXM=

  # echo -n "your-postgres-password" | base64
  POSTGRES_PASSWORD: REPLACE_WITH_BASE64

  # echo -n "ai_chatbot" | base64  →  YWlfY2hhdGJvdA==
  POSTGRES_DB: YWlfY2hhdGJvdA==
