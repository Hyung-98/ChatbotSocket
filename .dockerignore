# Node.js
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output (rebuilt inside Docker)
.next
out

# Environment files — NEVER bake secrets into the image
.env
.env.*
!.env.example

# Version control
.git
.gitignore

# IDE / editor
.vscode
.idea
*.swp
*.swo
.DS_Store

# Testing
coverage
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Docker files (avoid recursive inclusion)
Dockerfile
.dockerignore
docker-compose.yml
docker/

# Legacy Turborepo sub-packages (not part of the main Next.js app)
apps/
packages/

# Documentation
*.md
SETUP.md

# CI/CD
.github/

# Prisma local dev artifacts
prisma/dev.db
prisma/*.db-journal

# TypeScript build info
*.tsbuildinfo
next-env.d.ts
